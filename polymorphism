#include <iostream>
using namespace std;

class Complex
{
    int real;
    int img;
    
    public:
    Complex(int real,int img)
    {
        this->real=real;
        this->img=img;
    }
    void display()
    {
        cout<<real<<"+i"<<img<<endl;
    }
};
int main()
{
    Complex c1(3,2);
    c1.display();
    
    return 0;
}
