#include <iostream>
using namespace std;
//inheritance

class Human
{
    //properties
    protected:
    string name;
};
class Person
{
    protected:
    int age;
};
class Student: public Human, public Person
{
    int roll_no;
    public:
    Student(string n, int a, int r)
    {
        name=n;
        age=a;
        roll_no=r;
    }
    void display()
    {
        cout<<name<<" "<<age<<roll_no<<endl;
    }
};
int main()
{
    Student obj("Divya", 20, 01);
    obj.display();
    return 0;
}
